rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Private per-user images
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public shared recipe images — anyone can read, authenticated users can write
    match /sharedRecipes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
