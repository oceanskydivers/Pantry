        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PantryはInstagram、TikTok、Facebook、YouTubeのリンクからレシピをインポートできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry는 Instagram, TikTok, Facebook, YouTube 링크에서 레시피를 가져올 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Pantry pode importar receitas de links do Instagram, TikTok, Facebook e YouTube."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry может импортировать рецепты из ссылок Instagram, TikTok, Facebook и YouTube."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry, Instagram, TikTok, Facebook ve YouTube bağlantılarından tarif içe aktarabilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry 可以从 Instagram、TikTok、Facebook 和 YouTube 链接导入食谱。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry 可以從 Instagram、TikTok、Facebook 和 YouTube 連結匯入食譜。"
          }
        }
