    "Open Pantry now to import this recipe." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح Pantry الآن لاستيراد هذه الوصفة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই রেসিপি আমদানি করতে এখনই Pantry খুলুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffnen Sie jetzt Pantry, um dieses Rezept zu importieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre Pantry ahora para importar esta receta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez Pantry maintenant pour importer cette recette."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस रेसिपी को आयात करने के लिए अभी Pantry खोलें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka Pantry sekarang untuk mengimpor resep ini."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apri Pantry ora per importare questa ricetta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このレシピをインポートするには今すぐPantryを開いてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 레시피를 가져오려면 지금 Pantry를 여세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra o Pantry agora para importar esta receita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте Pantry, чтобы импортировать этот рецепт."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu tarifi içe aktarmak için Pantry'yi şimdi açın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "立即打开 Pantry 以导入此食谱。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "立即開啟 Pantry 以匯入此食譜。"
          }
        }
      }
    },
    "Pantry can import recipes from Instagram, TikTok, Facebook, and YouTube links." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن لـ Pantry استيراد الوصفات من روابط Instagram وTikTok وFacebook وYouTube."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry Instagram, TikTok, Facebook এবং YouTube লিঙ্ক থেকে রেসিপি আমদানি করতে পারে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry kann Rezepte von Instagram-, TikTok-, Facebook- und YouTube-Links importieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry puede importar recetas desde enlaces de Instagram, TikTok, Facebook y YouTube."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry peut importer des recettes depuis des liens Instagram, TikTok, Facebook et YouTube."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry Instagram, TikTok, Facebook और YouTube लिंक से रेसिपी आयात कर सकता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry dapat mengimpor resep dari tautan Instagram, TikTok, Facebook, dan YouTube."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry può importare ricette da link di Instagram, TikTok, Facebook e YouTube."
