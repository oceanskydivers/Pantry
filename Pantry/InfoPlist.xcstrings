    "NSSiriUsageDescription" : {
      "comment" : "Privacy - Siri Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم Pantry سيري لإضافة عناصر إلى قائمة التسوق بدون استخدام اليدين."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry Siri ব্যবহার করে আপনাকে হাত না লাগিয়ে শপিং লিস্টে আইটেম যোগ করতে দেয়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry verwendet Siri, damit Sie Artikel freihändig zu Ihrer Einkaufsliste hinzufügen können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pantry uses Siri to let you add items to your shopping list hands-free."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry usa Siri para permitirte agregar artículos a tu lista de compras sin manos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry utilise Siri pour vous permettre d'ajouter des articles à votre liste de courses en mode mains libres."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry Siri का उपयोग करके आपको हैंड्स-फ़्री अपनी शॉपिंग लिस्ट में आइटम जोड़ने देता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry menggunakan Siri agar Anda bisa menambahkan item ke daftar belanja secara hands-free."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry usa Siri per aggiungere articoli alla lista della spesa a mani libere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantryはハンズフリーで買い物リストにアイテムを追加するためにSiriを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry는 Siri를 사용하여 핸즈프리로 쇼핑 목록에 항목을 추가할 수 있게 합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Pantry usa a Siri para adicionar itens à sua lista de compras sem usar as mãos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry использует Siri, чтобы вы могли добавлять товары в список покупок без рук."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry, alışveriş listenize elleri serbest bırakarak ürün eklemek için Siri'yi kullanır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry 使用 Siri，让您免提向购物清单添加商品。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry 使用 Siri，讓您免持手將商品加入購物清單。"
          }
        }
      }
    }
