    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم Pantry الكاميرا لإضافة صور إلى الوصفات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry আপনার ক্যামেরা ব্যবহার করে রেসিপিতে ছবি যোগ করতে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry verwendet die Kamera, um Fotos zu Rezepten hinzuzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Pantry uses your camera to add photos to recipes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry usa tu cámara para agregar fotos a las recetas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry utilise votre appareil photo pour ajouter des photos aux recettes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry आपकी रेसिपी में फ़ोटो जोड़ने के लिए कैमरा का उपयोग करता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry menggunakan kamera Anda untuk menambahkan foto ke resep."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantry usa la fotocamera per aggiungere foto alle ricette."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pantryはレシピに写真を追加するためにカメラを使用します。"
