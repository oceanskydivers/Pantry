    "Share your sign-in credentials with your household members so everyone sees the same data in real time." : {
      "comment" : "A description of the sharing feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شارك بيانات اعتماد تسجيل الدخول الخاصة بك مع أفراد أسرتك ليرى الجميع نفس البيانات في الوقت الفعلي."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার পরিবারের সদস্যদের সাথে আপনার সাইন-ইন তথ্য শেয়ার করুন যাতে সবাই রিয়েল টাইমে একই ডেটা দেখতে পায়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teile deine Anmeldedaten mit deinen Haushaltsmitgliedern, damit alle dieselben Daten in Echtzeit sehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparte tus credenciales de inicio de sesión con los miembros de tu hogar para que todos vean los mismos datos en tiempo real."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partagez vos identifiants de connexion avec les membres de votre foyer afin que tout le monde voie les mêmes données en temps réel."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "अपने साइन-इन क्रेडेंशियल अपने घर के सदस्यों के साथ साझा करें ताकि सभी को रियल टाइम में एक ही डेटा दिखे।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bagikan kredensial masuk Anda dengan anggota rumah tangga Anda agar semua orang dapat melihat data yang sama secara real-time."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Condividi le tue credenziali di accesso con i membri della tua famiglia in modo che tutti possano vedere gli stessi dati in tempo reale."
          }
        },
        "ja" : {
          "stringUnit" : {
