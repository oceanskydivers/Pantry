    "Sign in to share recipes, inventory, and\nshopping lists across your household." : {
      "comment" : "A description of the benefits of signing in to Share.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سجل الدخول لمشاركة الوصفات والمخزون وقوائم\nالتسوق مع أفراد أسرتك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার পরিবারের সাথে রেসিপি, ইনভেন্টরি এবং\nকেনাকাটার তালিকা শেয়ার করতে সাইন ইন করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melde dich an, um Rezepte, Bestand und\nEinkaufslisten mit deinem Haushalt zu teilen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia sesión para compartir recetas, inventario y\nlistas de la compra con tu hogar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connectez-vous pour partager vos recettes, votre inventaire et\nvos listes de courses avec votre foyer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "रेसिपी, इन्वेंटरी और\nशॉपिंग लिस्ट अपने परिवार के साथ साझा करने के लिए साइन इन करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
