    "Items without a tracked consumption rate are excluded." : {
      "comment" : "A description below the dual wheel picker that explains that items without a tracked consumption rate are excluded from the filter.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم استبعاد العناصر التي ليس لها معدل استهلاك متتبع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যেসব আইটেমের ব্যবহারের হার ট্র্যাক করা হয়নি সেগুলো বাদ দেওয়া হয়েছে।"
          }
        },
        "de" : {
          "stringUnit" : {
