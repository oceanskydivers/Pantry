    " button to add more subcategories to an existing list." : {
      "comment" : "A description of how to add more subcategories to an existing list.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " زر لإضافة المزيد من الفئات الفرعية إلى قائمة موجودة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " বোতামটি একটি বিদ্যমান তালিকায় আরও উপশ্রেণি যোগ করার জন্য।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " Button, um einer bestehenden Liste weitere Unterkategorien hinzuzufügen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " botón para añadir más subcategorías a una lista existente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " bouton pour ajouter d'autres sous-catégories à une liste existante."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : " बटन से किसी मौजूदा सूची में और उप-श्रेणियां जोड़ें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " tombol untuk menambahkan lebih banyak subkategori ke daftar yang sudah ada."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " pulsante per aggiungere altre sottocategorie a un elenco esistente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "」ボタンをタップすると、既存のリストにさらにサブカテゴリを追加できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " 버튼을 탭하여 기존 목록에 하위 카테고리를 추가합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " botão para adicionar mais subcategorias a uma lista existente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " — кнопка для добавления новых подкатегорий в существующий список."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " düğmesi, mevcut bir listeye daha fazla alt kategori eklemek içindir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : " 按钮可将更多子分类添加到现有列表中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : " 按鈕可在現有清單中新增更多子分類。"
          }
        }
      }
    },
    " button to start nesting a new subcategory underneath an item." : {
      "comment" : "A description of how to create a subcategory.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " زر لبدء إدراج فئة فرعية جديدة أسفل عنصر ما."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " বোতামটি কোনো আইটেমের নিচে একটি নতুন উপশ্রেণি নেস্ট করা শুরু করার জন্য।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " Button, um eine neue Unterkategorie unter einem Element zu verschachteln."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " botón para empezar a anidar una nueva subcategoría debajo de un elemento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " bouton pour commencer à imbriquer une nouvelle sous-catégorie sous un élément."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : " बटन से किसी आइटम के नीचे नई उप-श्रेणी जोड़ना शुरू करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " tombol untuk mulai menyarangkan subkategori baru di bawah sebuah item."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
