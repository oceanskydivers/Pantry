    "Based on average since date bought. Log usage for a more accurate estimate." : {
      "comment" : "A description of how the estimate is calculated.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بناءً على المتوسط منذ تاريخ الشراء. سجل الاستخدام للحصول على تقدير أكثر دقة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "কেনার তারিখ থেকে গড়ের ওপর ভিত্তি করে। আরও সঠিক অনুমানের জন্য ব্যবহার লগ করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basierend auf dem Durchschnitt seit dem Kaufdatum. Protokolliere die Nutzung für eine genauere Schätzung."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basado en el promedio desde la fecha de compra. Registra el uso para obtener una estimación más precisa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
