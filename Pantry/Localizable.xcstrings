    "Add a category like \"Produce\" or \"Dairy\" to get started." : {
      "comment" : "A description of the shopping list.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف فئة مثل \"خضار وفواكه\" أو \"منتجات ألبان\" للبدء."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "শুরু করতে \"কাঁচাবাজার\" বা \"দুগ্ধজাত\"-এর মতো একটি বিভাগ যোগ করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge eine Kategorie wie \"Obst & Gemüse\" oder \"Milchprodukte\" hinzu, um loszulegen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade una categoría como \"Productos frescos\" o \"Lácteos\" para empezar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez une catégorie comme \"Produits frais\" ou \"Produits laitiers\" pour commencer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "शुरू करने के लिए \"सब्ज़ियाँ\" या \"डेयरी\" जैसी कोई कैटेगरी जोड़ें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tambahkan kategori seperti \"Bahan Segar\" atau \"Produk Susu\" untuk memulai."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi una categoria come \"Ortofrutta\" o \"Latticini\" per iniziare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "まずは「青果」や「乳製品」などのカテゴリを追加しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시작하려면 \"농산물\" 또는 \"유제품\"과 같은 카테고리를 추가하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione uma categoria como \"Hortifrúti\" ou \"Laticínios\" para começar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте категорию, например \"Овощи и фрукты\" или \"Молочные продукты\", чтобы начать."
          }
        },
        "tr" : {
