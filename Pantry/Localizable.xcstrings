    "Items assigned to this location will become unassigned." : {
      "comment" : "A message displayed in a confirmation dialog when deleting a location.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "العناصر المخصصة لهذا الموقع ستصبح غير مخصصة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই অবস্থানে বরাদ্দ করা আইটেমগুলো অনির্ধারিত হয়ে যাবে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Artikel, die diesem Lagerort zugewiesen sind, werden nicht mehr zugewiesen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los artículos asignados a esta ubicación pasarán a estar sin asignar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les articles attribués à cet emplacement ne seront plus associés."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "इस स्थान को असाइन किए गए आइटम अनअसाइन हो जाएंगे।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Item yang ditetapkan ke lokasi ini akan menjadi tidak ditetapkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli elementi assegnati a questa posizione diventeranno non assegnati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この場所に割り当てられているアイテムは、未割り当てになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
