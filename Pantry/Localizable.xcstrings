        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "खरीद की तारीख से औसत के आधार पर। अधिक सटीक अनुमान के लिए उपयोग लॉग करें।"
          }
        },
        "id" : {
          "stringUnit" : {
