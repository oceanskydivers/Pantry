    "Any recipes or changes you make while signed out won't be saved to your account.\n\nIf you get a new phone or device, you'll only be able to access the recipes that were synced to your account before signing out. Sign back in at any time to resume syncing." : {
      "comment" : "A message displayed in a confirmation alert when signing out.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "साइन आउट रहते हुए आप जो भी रेसिपी बनाएंगे या बदलाव करेंगे, वे अपने अकाउंट में सेव नहीं होंगे।\n\nयदि आप नया फ़ोन या डिवाइस लेते हैं, तो केवल वे रेसिपी एक्सेस कर पाएंगे जो साइन आउट करने से पहले अपने अकाउंट में सिंक हुई थीं। सिंकिंग फिर से शुरू करने के लिए कभी भी साइन इन करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "退出登录后所做的任何食谱添加或修改都不会保存到你的账户。\n\n如果你更换了手机或设备，只能访问退出前已同步至账户的食谱。随时重新登录即可恢复同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "登出後所做的任何食譜新增或修改都不會儲存到您的帳號。\n\n如果您更換了手機或裝置，只能存取登出前已同步至帳號的食譜。隨時重新登入即可恢復同步。"
          }
        }
      }
    },
    "Anyone who signs in with the same account (Apple ID, Google account, or email + password) will see and edit the same recipes, inventory, and shopping list in real time." : {
      "comment" : "A description of how household sharing works.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "जो भी एक ही अकाउंट (Apple ID, Google अकाउंट, या ईमेल + पासवर्ड) से साइन इन करेगा, वह रियल टाइम में एक ही रेसिपी, इन्वेंटरी और शॉपिंग लिस्ट देख और एडिट कर सकेगा।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "任何使用相同账户（Apple ID、Google账户或电子邮件 + 密码）登录的人都可以实时查看和编辑相同的食谱、库存和购物清单。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "任何使用相同帳號（Apple ID、Google 帳號或電子郵件＋密碼）登入的人，都能即時查看並編輯相同的食譜、庫存和購物清單。"
          }
        }
      }
    },
