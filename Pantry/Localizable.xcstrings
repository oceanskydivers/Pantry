          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se excluyen los artículos sin una tasa de consumo registrada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les articles sans taux de consommation suivi sont exclus."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बिना ट्रैक की गई खपत दर वाले आइटम बाहर रखे गए हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Item tanpa tingkat konsumsi yang dilacak akan dikecualikan."
          }
        },
        "it" : {
          "stringUnit" : {
