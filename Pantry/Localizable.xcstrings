        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই প্ল্যাটফর্মগুলোর যেকোনো একটি থেকে লিঙ্ক পেস্ট করুন এবং আমরা আপনার জন্য রেসিপিটি বের করে দেব:"
