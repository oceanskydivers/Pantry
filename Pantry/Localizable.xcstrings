    "No activity yet. Use + and — to log changes." : {
      "comment" : "A message displayed when a user has not yet logged any activity.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يوجد نشاط بعد. استخدم + و — لتسجيل التغييرات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এখনো কোনো কার্যকলাপ নেই। পরিবর্তনগুলো লগ করতে + এবং — ব্যবহার করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Noch keine Aktivität. Verwende + und —, um Änderungen zu protokollieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no hay actividad. Usa + y — para registrar los cambios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucune activité pour le moment. Utilisez + et — pour enregistrer les modifications."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "अभी तक कोई गतिविधि नहीं। बदलाव दर्ज करने के लिए + और — का उपयोग करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Belum ada aktivitas. Gunakan + dan — untuk mencatat perubahan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ancora nessuna attività. Usa + e — per registrare le modifiche."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アクティビティはまだありません。+ と — を使って変更を記録してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
