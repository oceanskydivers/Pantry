rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private per-user data — only the owning user can read/write
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public shared recipes
    // Anyone can read (supports web preview / OG tags without requiring sign-in)
    // Create / Update: any authenticated user, but must stamp createdBy with their own UID.
    //   Checking request.resource (incoming data) rather than resource (existing data) lets a
    //   user re-publish a recipe they originally shared under an anonymous UID after signing in.
    // Delete: only the current creator of the stored document
    match /sharedRecipes/{recipeId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }
  }
}
